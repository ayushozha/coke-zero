{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coke_zero.local/schemas/payloads/sda.schema.json",
  "title": "SDA Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "object_id",
    "event_type",
    "track_quality",
    "summary"
  ],
  "properties": {
    "object_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "catalog_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "object_type": {
      "type": "string",
      "enum": [
        "satellite",
        "debris",
        "rocket_body",
        "unknown"
      ]
    },
    "event_type": {
      "type": "string",
      "enum": [
        "conjunction",
        "maneuver",
        "breakup",
        "proximity",
        "track_update"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "range_km": {
      "type": "number",
      "minimum": 0
    },
    "relative_velocity_mps": {
      "type": "number",
      "minimum": 0
    },
    "track_quality": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
