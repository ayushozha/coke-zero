{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://canopy.local/schemas/payloads/osint.schema.json",
  "title": "OSINT Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "source_uri",
    "event_type",
    "summary",
    "language"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "source_uri": {
      "type": "string",
      "format": "uri"
    },
    "publisher": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "event_type": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "language": {
      "type": "string",
      "pattern": "^[a-z]{2,3}(-[A-Z]{2})?$"
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80
      },
      "uniqueItems": true
    }
  }
}
