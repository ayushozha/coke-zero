{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://halo.local/schemas/signal.schema.json",
  "title": "CANOPY Signal",
  "description": "Canonical Signal emitted by every CANOPY data adapter, real or mock.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "ts",
    "domain",
    "source",
    "realism",
    "confidence",
    "payload",
    "provenance"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "domain": {
      "type": "string",
      "enum": [
        "sda",
        "orbit",
        "osint",
        "humint",
        "rf_ew",
        "cyber",
        "pnt",
        "satcom",
        "drone",
        "terrain"
      ]
    },
    "source": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "realism": {
      "type": "string",
      "enum": [
        "real_source",
        "mock_operational",
        "synthetic_orbital_overlay"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "location": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "label": {
          "type": "string"
        },
        "lat": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "lng": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "alt_km": {
          "type": "number"
        }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "event_type",
        "summary"
      ],
      "properties": {
        "beat": {
          "type": "string"
        },
        "event_type": {
          "type": "string",
          "minLength": 1
        },
        "asset": {
          "type": "string"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "observables": {
          "type": "object"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "source_id"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "citation": {
          "type": [
            "string",
            "null"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
