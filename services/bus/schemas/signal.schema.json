{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://halo.local/schemas/signal.schema.json",
  "title": "CANOPY Signal",
  "description": "Canonical Signal emitted by every CANOPY data adapter, real or mock.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "ts",
    "domain",
    "source",
    "realism",
    "confidence",
    "location",
    "payload",
    "provenance"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "domain": {
      "type": "string",
      "enum": [
        "sda",
        "orbit",
        "osint",
        "humint",
        "rf_ew",
        "cyber",
        "pnt",
        "satcom",
        "drone",
        "terrain"
      ]
    },
    "source": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "realism": {
      "type": "string",
      "enum": [
        "real_source",
        "mock_operational",
        "synthetic_orbital_overlay"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "location": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": true,
      "anyOf": [
        {
          "required": [
            "lat",
            "lng"
          ]
        },
        {
          "required": [
            "mgrs"
          ]
        },
        {
          "required": [
            "area_wkt"
          ]
        },
        {
          "required": [
            "label"
          ]
        }
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "lat": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "lng": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "alt_km": {
          "type": "number"
        },
        "alt_m": {
          "type": "number"
        },
        "ce_m": {
          "type": "number",
          "minimum": 0
        },
        "mgrs": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "area_wkt": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "event_type",
        "summary"
      ],
      "properties": {
        "beat": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32
        },
        "event_type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "asset": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "observables": {
          "type": "object"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "source_id"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "citation": {
          "type": [
            "string",
            "null"
          ]
        },
        "collector": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "method": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "references": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string",
          "maxLength": 2000
        }
      }
    }
  }
}
