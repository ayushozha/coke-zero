#!/usr/bin/env bash
set -euo pipefail

if command -v uv >/dev/null 2>&1; then
  exec uv run "$@"
fi

if [ -x "$HOME/.local/bin/uv" ]; then
  exec "$HOME/.local/bin/uv" run "$@"
fi

cat >&2 <<'EOF'
uv is required but was not found on PATH or at $HOME/.local/bin/uv.

Install it with:
  curl -LsSf https://astral.sh/uv/install.sh | sh

Then restart your terminal or run:
  export PATH="$HOME/.local/bin:$PATH"
EOF
exit 127
