# Copy to `.env` or `.env.local` and fill in. Local env files are gitignored.
#
# Required when running with --live (the AnthropicLLMClient path). Stub-only
# runs do not need this key.
ANTHROPIC_API_KEY=

# Optional: override the default Anthropic model used by attrib + decide.
# Default is claude-sonnet-4-6.
# CANOPY_ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: force --live mode without passing the flag. Any non-empty value
# enables it.
# CANOPY_LIVE=1

# Optional: enables Cesium ion world imagery in the frontend. When omitted,
# the frontend falls back to Esri World Imagery and then local Natural Earth.
VITE_CESIUM_ION_TOKEN=

# Optional: frontend WebSocket bridge URL. In dev the UI defaults to this
# value if it is not set.
VITE_CANOPY_WS_URL=ws://127.0.0.1:8000/ws/brigade
