# Copy to `.env` or `.env.local` and fill in. Local env files are gitignored.

# ---- Hackathon / app identity --------------------------------------------
NOZOMIO_APP_NAME=coke-zero
JWT_SECRET=

# ---- OpenAI / Anthropic / local model providers --------------------------
#
# OpenAI is optional for sponsor demos, triage experiments, and fallback
# reasoning paths. coke-zero's current engine uses Anthropic, Ollama, or stub
# through COKE_ZERO_LLM.
OPENAI_API_KEY=
OPENAI_TRIAGE_MODEL=gpt-4.1-mini

# Required when running with --live (the AnthropicLLMClient path). Stub-only
# runs do not need this key.
ANTHROPIC_API_KEY=

# Optional: override the default Anthropic model used by attrib + decide.
COKE_ZERO_ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: force --live mode without passing the flag. Any non-empty value
# enables it.
COKE_ZERO_LIVE=

# Optional: choose stub, anthropic, or ollama without passing --llm.
COKE_ZERO_LLM=

# Optional: backend bridge logging and attribution timing defaults.
COKE_ZERO_LOG_LEVEL=INFO
COKE_ZERO_ATTRIB_WINDOW_S=0.5
COKE_ZERO_MEMORY_PATH=data/mission_memory.json

# ---- Local LLM via Ollama (alternative to Anthropic) -----------------------
#
# Set COKE_ZERO_LLM=ollama (or pass --llm ollama) to route attribution and
# decision through a local model on your Ollama server. Useful for offline
# demos and to avoid burning API credit during dev.
#
# Ollama daemon URL. Over Tailscale this is typically the MagicDNS hostname
# or 100.x.x.x IP, e.g. http://kettle:11434 or http://100.64.0.1:11434.
COKE_ZERO_OLLAMA_URL=http://localhost:11434
#
# Model tag served by your Ollama daemon. Larger models give better tool-use
# discipline; smaller ones are faster on a 24 GB GPU.
COKE_ZERO_OLLAMA_MODEL=gemma4:26b
#
# Per-request timeout in seconds. Local inference on a 26B model can take
# 30-90 s per call; 180 s is a comfortable default.
COKE_ZERO_OLLAMA_TIMEOUT_S=180

# ---- Live orbital refresh --------------------------------------------------
#
# Optional: required only when refreshing N2YO orbital cache files with
# scripts/fetch_n2yo_satellite.py. The app can run from checked-in fixtures
# without this key.
N2YO_API_KEY=
N2YO_OBSERVER_LAT=0.0
N2YO_OBSERVER_LNG=0.0
N2YO_OBSERVER_ALT_M=0.0

# Optional: enables Cesium ion world imagery in the frontend. When omitted,
# the frontend falls back to Esri World Imagery and then local Natural Earth.
VITE_CESIUM_ION_TOKEN=

# Optional: frontend HTTP API bridge URL. In dev the UI defaults to this
# value if it is not set.
VITE_COKE_ZERO_API_URL=http://127.0.0.1:8000

# Optional: frontend WebSocket bridge URL. In dev the UI defaults to this
# value if it is not set.
VITE_COKE_ZERO_WS_URL=ws://127.0.0.1:8000/ws

# Optional: public deployment backend URLs. Production builds intentionally use
# these deploy-specific names so local loopback URLs are not embedded in the
# submitted client bundle.
VITE_COKE_ZERO_PUBLIC_API_URL=
VITE_COKE_ZERO_PUBLIC_WS_URL=

# ---- Sponsor integrations -------------------------------------------------
#
# Nia: primary context layer for docs, scenarios, repo code, KB entries, and
# public-source notes. The local Nia CLI may also be configured via nia.json.
# Add NIA_API_KEY here if the integration path uses env-based auth.
NIA_API_KEY=
COKE_ZERO_NIA_ENABLED=1
COKE_ZERO_NIA_TIMEOUT_S=12
NIA_CLI=npx -y @nozomioai/nia

# Tensorlake: always-on/background execution and durable sandbox workers.
TENSORLAKE_API_KEY=

# Hyperspell: optional company-brain / cross-source memory integration.
HYPERSPELL_API_KEY=

# InsForge: optional production shell, auth, backend, and model gateway path.
INSFORGE_API_URL=
INSFORGE_API_KEY=

# Convex: optional realtime product-state backend if the demo pivots toward a
# deployed full-stack control plane.
CONVEX_DEPLOYMENT=
CONVEX_ACCESS_TOKEN=
NEXT_PUBLIC_CONVEX_URL=

# GitHub: optional OAuth/API integration for repo or PR-review context demos.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
