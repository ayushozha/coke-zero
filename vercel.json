{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist-web",
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/brigade",
      "destination": "/index.html"
    },
    {
      "source": "/operator",
      "destination": "/index.html"
    },
    {
      "source": "/demo",
      "destination": "/index.html"
    }
  ]
}
